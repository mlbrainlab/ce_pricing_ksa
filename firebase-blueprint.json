{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "cp", "internal"] },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "defaultDealType": { "type": "string" },
        "defaultChannel": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["email", "status", "role"]
    },
    "Quote": {
      "title": "Quote",
      "description": "Saved quotes and drafts.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "quoteName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "final"] },
        "version": { "type": "number" },
        "parentQuoteId": { "type": "string" },
        "config": { "type": "map" },
        "results": { "type": "map" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["userId", "quoteName", "status", "version", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles stored by uid"
    },
    "/quotes/{quoteId}": {
      "schema": { "$ref": "#/entities/Quote" },
      "description": "Quotes created by users"
    }
  }
}
